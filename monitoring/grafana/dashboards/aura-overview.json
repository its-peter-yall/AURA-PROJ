      "pluginVersion": "10.2.0",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"aura-chat-api\"}[5m])) by (le))",
          "legendFormat": "AURA-CHAT P95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"aura-notes-api\"}[5m])) by (le))",
          "legendFormat": "AURA-NOTES P95",
          "refId": "B"
        }
      ],
      "title": "API Latency P95",
      "type": "stat"
